rules_version = '2';

// Files live under teams/{teamId}/huddles/{huddleId}/{fileName}.
// Only members of the team (looked up in Firestore) may read or upload.
service firebase.storage {
  match /b/{bucket}/o {
    match /teams/{teamId}/huddles/{huddleId}/{fileName} {
      allow read, write: if request.auth != null
        && request.auth.uid in
           firestore.get(/databases/(default)/documents/teams/$(teamId)).data.members;
    }
  }
}
